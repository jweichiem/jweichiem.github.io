{
	"name": "joakim-cv",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:ssr": "node --experimental-strip-types server/index.ts",
		"analyze": "vite build --mode analyze --outDir dist/analyze",
		"build": "tsc -b && npm run build:ssr",
		"build:ssr": "vite build --outDir dist/client && vite build --ssr client/entry/server.tsx --outDir dist/server",
		"build:ssg": "npm run build && node --experimental-strip-types server/static-site-generator.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"start:ssr": "NODE_ENV=production node --experimental-strip-types server/index.ts",
		"test": "vitest",
		"test:a11y": "vitest run --config vitest.config.ts client/entry/test/accessibility.test.ts",
		"test:server": "vitest run --config vitest.config.ts"
	},
	"dependencies": {
		"@fastify/middie": "^9.3.1",
		"@fastify/static": "^9.0.0",
		"fastify": "^5.8.2",
		"modern-normalize": "^3.0.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"wouter": "^3.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"axe-core": "^4.11.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"jsdom": "^28.1.0",
		"sass": "1.97.3",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-bundle-analyzer": "^1.3.6",
		"vitest": "^4.0.18"
	}
}
